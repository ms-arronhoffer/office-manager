---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import DashboardScreen from '../../components/screens/DashboardScreen.astro';
import LeaseAbstractScreen from '../../components/screens/LeaseAbstractScreen.astro';
import MaintenanceScreen from '../../components/screens/MaintenanceScreen.astro';
import WaiversScreen from '../../components/screens/WaiversScreen.astro';
import AnalyticsScreen from '../../components/screens/AnalyticsScreen.astro';
import { tutorials } from '../../config/site';
import { tutorialContent } from '../../config/tutorialContent';

export function getStaticPaths() {
  return tutorials.map(t => ({ params: { slug: t.slug }, props: { tutorial: t } }));
}

const { tutorial } = Astro.props;
const body = tutorialContent[tutorial.slug];
const nextMeta = body.next ? tutorials.find(t => t.slug === body.next) : undefined;
---
<Layout
  title={`${tutorial.title} — Office Manager Tutorials`}
  description={tutorial.summary}
>
  <Navbar />
  <main>
    <!-- Header -->
    <section class="border-b border-slate-100 bg-slate-50">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
        <a href="/tutorials" class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors mb-6">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5M11 18l-6-6 6-6"/></svg>
          All tutorials
        </a>
        <div class="flex items-center gap-2 mb-4">
          <span class="text-xs font-semibold px-2.5 py-0.5 rounded-full bg-blue-100 text-blue-700">{tutorial.level}</span>
          <span class="text-xs text-slate-400">{tutorial.minutes} min read</span>
        </div>
        <h1 class="text-3xl lg:text-4xl font-extrabold text-slate-900 tracking-tight">{tutorial.title}</h1>
        <p class="mt-4 text-lg text-slate-600 leading-relaxed">{body.intro}</p>
      </div>
    </section>

    <article class="py-14">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        {body.screen && (
          <div class="relative mb-12">
            {body.screen === 'dashboard' && <DashboardScreen />}
            {body.screen === 'lease' && <LeaseAbstractScreen />}
            {body.screen === 'maintenance' && <MaintenanceScreen />}
            {body.screen === 'waivers' && <WaiversScreen />}
            {body.screen === 'analytics' && <AnalyticsScreen />}
          </div>
        )}

        <ol class="space-y-8">
          {body.steps.map((step, i) => (
            <li class="flex gap-5">
              <div class="flex-shrink-0 w-9 h-9 rounded-full bg-blue-600 text-white font-bold flex items-center justify-center text-sm">{i + 1}</div>
              <div>
                <h2 class="text-lg font-bold text-slate-900">{step.title}</h2>
                <p class="mt-1.5 text-slate-600 leading-relaxed">{step.body}</p>
              </div>
            </li>
          ))}
        </ol>

        {body.tip && (
          <div class="mt-12 rounded-2xl border border-blue-100 bg-blue-50/60 p-5 flex gap-3">
            <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2a7 7 0 00-4 12.7V17a1 1 0 001 1h6a1 1 0 001-1v-2.3A7 7 0 0012 2zM9 21h6"/></svg>
            <div>
              <div class="text-sm font-semibold text-slate-900">Pro tip</div>
              <p class="text-sm text-slate-600 leading-relaxed mt-0.5">{body.tip}</p>
            </div>
          </div>
        )}

        <!-- CTA + next -->
        <div class="mt-14 grid sm:grid-cols-2 gap-4">
          <a href="#" data-href="SIGNUP_URL" class="rounded-2xl bg-slate-900 text-white p-6 hover:bg-slate-700 transition-colors">
            <div class="text-sm font-semibold text-blue-300">Ready to try it?</div>
            <div class="mt-1 font-bold text-lg">Start your free 14-day trial</div>
            <div class="mt-3 inline-flex items-center gap-1.5 text-sm font-medium">Get started <span aria-hidden="true">→</span></div>
          </a>
          {nextMeta && (
            <a href={`/tutorials/${nextMeta.slug}`} class="rounded-2xl border border-slate-200 bg-white p-6 hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50 transition-all">
              <div class="text-sm font-semibold text-slate-400">Next tutorial</div>
              <div class="mt-1 font-bold text-lg text-slate-900">{nextMeta.title}</div>
              <div class="mt-3 inline-flex items-center gap-1.5 text-sm font-medium text-blue-600">Continue <span aria-hidden="true">→</span></div>
            </a>
          )}
        </div>
      </div>
    </article>
  </main>
  <Footer />
</Layout>
