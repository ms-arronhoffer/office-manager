---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import Pricing from '../components/Pricing.astro';
import Cta from '../components/Cta.astro';

const faqs = [
  {
    q: 'Is there really a free trial?',
    a: 'Yes — every plan includes a 14-day free trial with no credit card required. Import your data and explore the full product before you commit.',
  },
  {
    q: 'Do you charge per user?',
    a: 'No. Every plan includes unlimited users. You pay based on the number of offices in your portfolio, so your whole team can collaborate without seat math.',
  },
  {
    q: 'Can I change plans later?',
    a: 'Absolutely. Upgrade or downgrade at any time as your portfolio grows. Annual billing unlocks a discounted rate shown on each plan.',
  },
  {
    q: 'What happens to my data if I cancel?',
    a: 'Your data is always yours. Export leases, tickets, vendors, and reports to CSV or PDF at any time. Cancel whenever you like — no lock-in.',
  },
  {
    q: 'Which plan includes AI and digital waivers?',
    a: 'AI lease detail extraction is available on every plan. AI abstracts, AI briefings, and digital waivers with e-signatures are included on Pro and Enterprise.',
  },
];
---
<Layout
  title="Pricing — Office Manager Plans for Every Portfolio"
  description="Simple, transparent pricing with unlimited users on every plan. Starter, Pro, and Enterprise tiers with a 14-day free trial and no credit card required."
>
  <Navbar />
  <main>
    <PageHero
      eyebrow="Pricing"
      title="One price for your whole team"
      subtitle="No per-seat nonsense. No hidden fees. Pick a plan by portfolio size and invite everyone."
    />
    <Pricing />

    <!-- FAQ -->
    <section class="py-20 bg-slate-50 border-t border-slate-100">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-extrabold text-slate-900 text-center mb-10">Pricing questions, answered</h2>
        <div class="space-y-4">
          {faqs.map(f => (
            <details class="group rounded-2xl border border-slate-200 bg-white p-5">
              <summary class="flex items-center justify-between cursor-pointer list-none font-semibold text-slate-900">
                {f.q}
                <svg class="w-5 h-5 text-slate-400 transition-transform group-open:rotate-45" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 5v14M5 12h14"/></svg>
              </summary>
              <p class="mt-3 text-sm text-slate-500 leading-relaxed">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Cta />
  <Footer />
</Layout>
