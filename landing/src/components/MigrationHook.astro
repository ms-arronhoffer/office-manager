---
// First-class "switch from Buildium" hook. Targets the highest-intent, lowest-
// friction segment: teams already shopping to leave a competitor. Placed high
// on the page (right after the credibility strip) with its own CTA.
---
<section id="migration" class="py-16 lg:py-20 bg-slate-900 relative overflow-hidden">
  <div class="absolute inset-0 -z-0 opacity-20" aria-hidden="true">
    <div class="absolute -top-24 -right-24 w-96 h-96 bg-blue-600 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-24 -left-24 w-96 h-96 bg-blue-500 rounded-full blur-3xl"></div>
  </div>
  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-10 items-center">
      <div>
        <div class="inline-flex items-center gap-2 bg-blue-500/15 border border-blue-400/30 text-blue-300 text-xs font-bold uppercase tracking-widest px-3 py-1.5 rounded-full mb-5">
          Switching platforms?
        </div>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-white leading-tight">
          Coming from Buildium?<br/>We migrate your whole portfolio, free.
        </h2>
        <p class="mt-5 text-lg text-slate-300 leading-relaxed">
          Our guided migration assistant maps and moves your leases, tenants, vendors and GL
          account mappings straight across, so switching takes hours, not weeks. No re-keying,
          no data left behind, no downtime for your team.
        </p>
        <ul class="mt-6 grid sm:grid-cols-2 gap-3">
          {[
            'Leases, terms & critical dates',
            'Tenants & contacts',
            'Vendors & insurance certs',
            'GL accounts & mappings',
          ].map(item => (
            <li class="flex items-center gap-2 text-sm text-slate-200">
              <svg class="w-4 h-4 text-blue-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              {item}
            </li>
          ))}
        </ul>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="bg-white text-slate-900 font-semibold px-7 py-3 rounded-xl hover:bg-slate-100 transition-colors text-center">
            See how migration works
          </a>
          <a href="#" data-href="SIGNUP_URL" class="bg-transparent text-white font-semibold px-7 py-3 rounded-xl border-2 border-slate-600 hover:border-slate-400 transition-colors text-center">
            Start free & import later
          </a>
        </div>
      </div>

      <!-- Simple before/after migration visual -->
      <div class="relative">
        <div class="rounded-2xl border border-slate-700 bg-slate-800/60 backdrop-blur p-6">
          <div class="flex items-center justify-between gap-4">
            <div class="flex-1 text-center">
              <div class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-2">From</div>
              <div class="rounded-xl border border-slate-600 bg-slate-900/60 py-6 px-3 text-slate-300 font-semibold">Buildium export</div>
            </div>
            <svg class="w-8 h-8 text-blue-400 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M4 12h16M14 6l6 6-6 6"/></svg>
            <div class="flex-1 text-center">
              <div class="text-xs font-semibold text-blue-300 uppercase tracking-widest mb-2">To</div>
              <div class="rounded-xl border border-blue-500/40 bg-blue-500/10 py-6 px-3 text-white font-semibold" data-company>Portfolio Desk</div>
            </div>
          </div>
          <div class="mt-6 space-y-2">
            {[
              ['Leases mapped', '100%'],
              ['Tenants imported', '100%'],
              ['Vendors + COIs', '100%'],
              ['GL accounts linked', '100%'],
            ].map(([label, val]) => (
              <div class="flex items-center gap-3">
                <span class="text-xs text-slate-400 w-32 flex-shrink-0">{label}</span>
                <span class="flex-1 h-2 rounded-full bg-slate-700 overflow-hidden">
                  <span class="block h-full w-full bg-blue-500 rounded-full"></span>
                </span>
                <span class="text-xs font-semibold text-blue-300">{val}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
