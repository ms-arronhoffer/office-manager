---
import ProductVideo from './screens/ProductVideo.astro';
import TrustBadges from './TrustBadges.astro';
---
<section class="relative pt-20 pb-24 lg:pt-28 lg:pb-32 overflow-hidden">

  <!-- Soft grid background -->
  <div class="absolute inset-0 -z-10" aria-hidden="true">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#f1f5f9_1px,transparent_1px),linear-gradient(to_bottom,#f1f5f9_1px,transparent_1px)] bg-[size:48px_48px]"></div>
    <div class="absolute top-0 left-0 right-0 h-72 bg-gradient-to-b from-white to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-white to-transparent"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

    <!-- Pain-point banner: quantified cost of the status quo -->
    <div class="inline-flex items-center gap-2 bg-amber-50 border border-amber-200 text-amber-800 text-sm font-medium px-4 py-1.5 rounded-full mb-6">
      <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86l-8.48 14.7A2 2 0 003.53 21h16.94a2 2 0 001.72-2.44L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
      One missed renewal or auto-renew notice can cost six figures
    </div>

    <!-- Heading -->
    <h1 class="text-5xl lg:text-7xl font-extrabold text-slate-900 leading-[1.05] tracking-tight max-w-4xl mx-auto">
      Never miss another<br/>
      lease deadline<br/>
      <span class="text-blue-600">or maintenance SLA.</span>
    </h1>

    <p class="mt-8 text-lg lg:text-xl text-slate-600 max-w-2xl mx-auto leading-relaxed">
      Spreadsheets and email chains lose the dates that cost the most. Portfolio Desk gives your team
      one platform to track every lease, deadline, ticket and vendor, with built-in AI that reads your
      leases and writes your reports, so nothing critical slips through.
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#" data-href="SIGNUP_URL" class="bg-slate-900 text-white font-semibold text-base px-8 py-3.5 rounded-xl hover:bg-slate-700 transition-colors shadow-lg shadow-slate-900/10">
        Start Free Trial: Free 14 days
      </a>
      <a href="#product-tour" class="bg-white text-slate-800 font-semibold text-base px-8 py-3.5 rounded-xl border-2 border-slate-200 hover:border-slate-400 transition-colors inline-flex items-center justify-center gap-2">
        <svg class="w-4 h-4 text-blue-600" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        Watch the 15-second tour
      </a>
    </div>

    <p class="mt-5 text-sm text-slate-400">No credit card required &nbsp;·&nbsp; Setup in under an hour &nbsp;·&nbsp; Cancel anytime</p>

    <!-- Live product walkthrough video (built from real captured screens) -->
    <div id="product-tour" class="mt-16 relative max-w-5xl mx-auto scroll-mt-24">
      <ProductVideo />
      <!-- Glow -->
      <div class="absolute -inset-4 -z-10 bg-blue-100/40 rounded-3xl blur-3xl"></div>
    </div>

    <!-- Trust signals immediately under the fold -->
    <div class="mt-12">
      <TrustBadges />
    </div>

  </div>
</section>
