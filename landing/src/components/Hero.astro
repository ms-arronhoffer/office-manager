---
import DashboardScreen from './screens/DashboardScreen.astro';
---
<section class="relative pt-20 pb-24 lg:pt-32 lg:pb-36 overflow-hidden">

  <!-- Soft grid background -->
  <div class="absolute inset-0 -z-10" aria-hidden="true">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#f1f5f9_1px,transparent_1px),linear-gradient(to_bottom,#f1f5f9_1px,transparent_1px)] bg-[size:48px_48px]"></div>
    <div class="absolute top-0 left-0 right-0 h-72 bg-gradient-to-b from-white to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-white to-transparent"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-blue-50 border border-blue-100 text-blue-700 text-sm font-medium px-4 py-1.5 rounded-full mb-8">
      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd"/>
      </svg>
      Corporate Real Estate &amp; Facilities Management
    </div>

    <!-- Heading -->
    <h1 class="text-5xl lg:text-7xl font-extrabold text-slate-900 leading-[1.05] tracking-tight max-w-4xl mx-auto">
      Every office.<br/>
      Every lease.<br/>
      <span class="text-blue-600">Every deadline.</span>
    </h1>

    <p class="mt-8 text-lg lg:text-xl text-slate-600 max-w-2xl mx-auto leading-relaxed">
      Stop juggling spreadsheets and email chains. Portfolio Desk gives your team a single platform
      to track leases, manage maintenance, handle vendors, and never miss a critical date,
      all with built-in AI that reads your leases and writes your reports.
    </p>

    <!-- CTAs -->
    <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#" data-href="SIGNUP_URL" class="bg-slate-900 text-white font-semibold text-base px-8 py-3.5 rounded-xl hover:bg-slate-700 transition-colors shadow-lg shadow-slate-900/10">
        Start Free Trial: Free 14 days
      </a>
      <a href="/contact" class="bg-white text-slate-800 font-semibold text-base px-8 py-3.5 rounded-xl border-2 border-slate-200 hover:border-slate-400 transition-colors">
        Request a Demo →
      </a>
    </div>

    <p class="mt-5 text-sm text-slate-400">No credit card required &nbsp;·&nbsp; Setup in under an hour &nbsp;·&nbsp; Cancel anytime</p>

    <!-- Dashboard screenshot -->
    <div class="mt-16 relative max-w-5xl mx-auto">
      <DashboardScreen />
      <!-- Glow -->
      <div class="absolute -inset-4 -z-10 bg-blue-100/40 rounded-3xl blur-3xl"></div>
    </div>

  </div>
</section>
