---
---
<section class="py-16 border-y border-slate-100 bg-slate-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-sm font-semibold text-slate-400 uppercase tracking-widest mb-10">
      Built to move the numbers that matter to facilities teams
    </p>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
      {[
        { value: 'Every', label: 'Critical lease date tracked & alerted' },
        { value: '< 1 hr', label: 'Typical time to first office live' },
        { value: 'Hours/wk', label: 'Manual tracking automated away' },
        { value: '1 place', label: 'Leases, tickets, vendors & books' },
      ].map(stat => (
        <div class="text-center">
          <div class="text-3xl lg:text-4xl font-extrabold text-slate-900">{stat.value}</div>
          <div class="mt-1 text-sm text-slate-500">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
