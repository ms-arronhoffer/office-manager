---
---
<header class="sticky top-0 z-50 bg-white/80 backdrop-blur border-b border-slate-100">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="#" class="flex items-center gap-2.5 font-bold text-slate-900 text-lg">
        <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center flex-shrink-0">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
            <rect x="3" y="3.5" width="12" height="1.8" rx="0.9" fill="white"/>
            <rect x="3" y="8" width="8" height="1.8" rx="0.9" fill="white" opacity=".75"/>
            <rect x="3" y="12.5" width="10" height="1.8" rx="0.9" fill="white" opacity=".5"/>
          </svg>
        </div>
        <span data-company>Office Manager</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-8 text-sm font-medium text-slate-600">
        <a href="#features" class="hover:text-slate-900 transition-colors">Features</a>
        <a href="#how-it-works" class="hover:text-slate-900 transition-colors">How it works</a>
        <a href="#pricing" class="hover:text-slate-900 transition-colors">Pricing</a>
      </nav>

      <!-- CTAs -->
      <div class="flex items-center gap-3">
        <a href="#" data-href="LOGIN_URL" class="hidden sm:block text-sm font-medium text-slate-600 hover:text-slate-900 transition-colors">
          Sign in
        </a>
        <a href="#" data-href="SIGNUP_URL" class="bg-slate-900 text-white text-sm font-semibold px-4 py-2 rounded-lg hover:bg-slate-700 transition-colors">
          Start Free Trial
        </a>
      </div>

    </div>
  </div>
</header>
