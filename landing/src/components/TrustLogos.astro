---
// "Trusted by" style credibility strip. We do not have permission to show real
// customer logos, so instead of fabricating them we show the industry segments
// the product is built for, framed directionally (honest, not a false claim).
const industries = [
  'Financial Services',
  'Healthcare',
  'Technology',
  'Retail & Franchise',
  'Logistics & Industrial',
  'Property Management',
];
---
<section class="py-12 border-b border-slate-100 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-sm font-semibold text-slate-400 uppercase tracking-widest mb-8">
      Purpose-built for multi-location portfolios across
    </p>
    <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-3">
      {industries.map(name => (
        <span class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm font-semibold text-slate-600">
          <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 21h18M5 21V7l7-4 7 4v14M9 9h.01M9 13h.01M9 17h.01M15 9h.01M15 13h.01M15 17h.01"/></svg>
          {name}
        </span>
      ))}
    </div>
  </div>
</section>
