---
// The top differentiators are promoted into large "hero feature" blocks so they
// don't drown in a 13-tile grid. Everything else is kept as a compact scannable
// list so the section stays complete without feeling like a spec dump.
const heroFeatures = [
  {
    icon: `<path d="M12 2l2.4 6.6L21 11l-6.6 2.4L12 20l-2.4-6.6L3 11l6.6-2.4L12 2z"/>`,
    title: 'AI that reads your leases',
    desc: 'Powered by Google Gemini. Upload a lease and the AI extracts key terms, drafts a clause-by-clause abstract, and writes weekly & monthly briefings of upcoming notice periods and expirations, so the deadlines find you.',
    tag: 'Pro & up',
  },
  {
    icon: `<path d="M16 3l4 4-4 4M20 7H4M8 21l-4-4 4-4M4 17h16"/>`,
    title: 'Free Buildium migration',
    desc: 'A guided migration assistant maps and moves your leases, tenants, vendors and GL account mappings straight over from Buildium, so switching platforms takes hours instead of weeks.',
    tag: 'Switchers',
  },
  {
    icon: `<path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/><path d="M3 5c0 1.66 4 3 9 3s9-1.34 9-3-4-3-9-3-9 1.34-9 3z"/><path d="M9 12l2 2 4-4"/>`,
    title: 'Digital waivers & e-signatures',
    desc: 'Send pre-built or custom waivers to any contact or walk-in visitor. Captures consent, attribution and a tamper-evident audit trail conforming to ESIGN/UETA e-signature standards.',
    tag: 'Pro & up',
  },
  {
    icon: `<path d="M18 20V10M12 20V4M6 20v-6"/>`,
    title: 'Portfolio analytics & reporting',
    desc: 'Portfolio-level dashboards, SLA compliance reports, cost-per-sq-ft trending and maintenance backlog summaries. Export to PDF or CSV for leadership in a click.',
    tag: 'Included',
  },
];

const moreFeatures = [
  { title: 'Lease Management', desc: 'Track every term, option, escalation and critical notice date with proactive alerts and full document storage.' },
  { title: 'Maintenance Tickets', desc: 'Submit, assign and track work orders with SLA timers, vendor assignment, photos and full notes history.' },
  { title: 'HVAC & Equipment', desc: 'Schedule preventive maintenance, track service contracts and stay ahead of inspection requirements.' },
  { title: 'Vendor Management', desc: 'Centralize vendor contacts, contracts and insurance certificates, with compliance visible per location.' },
  { title: 'Finance Hub', desc: 'Run rent roll, operating-expense tracking and general-ledger workflows from one shared finance workspace.' },
  { title: 'Smart Notifications', desc: 'Rule-based email alerts for every critical event, routed to the right person before the deadline, not after.' },
  { title: 'Transition Management', desc: 'Plan office moves, buildouts and lease-end activities with milestone checklists and status tracking.' },
  { title: 'Roll-Up Categories', desc: 'Grouped navigation keeps high-traffic workflows organized and easy to scan as your stack grows.' },
  { title: 'Audit Log', desc: 'Every action logged with user, timestamp and change detail — a full audit trail built for compliance.' },
];
---
<section id="features" class="py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="text-sm font-semibold text-blue-600 uppercase tracking-widest mb-3">Features</p>
      <h2 class="text-4xl lg:text-5xl font-extrabold text-slate-900">Everything your facilities team needs</h2>
      <p class="mt-4 text-lg text-slate-500">Built specifically for corporate real estate and facilities management, not a generic tool bent to fit.</p>
    </div>

    <!-- Promoted differentiators -->
    <div class="grid md:grid-cols-2 gap-6 mb-14">
      {heroFeatures.map(f => (
        <div class="group relative p-8 rounded-2xl border border-slate-200 bg-white hover:border-blue-200 hover:shadow-xl hover:shadow-blue-50 transition-all duration-200">
          <div class="flex items-start justify-between">
            <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center mb-5 group-hover:bg-blue-100 transition-colors">
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" set:html={f.icon} />
            </div>
            <span class="text-xs font-semibold text-blue-600 bg-blue-50 rounded-full px-3 py-1">{f.tag}</span>
          </div>
          <h3 class="text-xl font-bold text-slate-900 mb-2">{f.title}</h3>
          <p class="text-slate-500 leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>

    <!-- Condensed list of the rest -->
    <div class="text-center mb-8">
      <p class="text-sm font-semibold text-slate-400 uppercase tracking-widest">Plus everything else you'd expect</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-6">
      {moreFeatures.map(f => (
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.4" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
          <div>
            <h3 class="font-semibold text-slate-900 text-sm">{f.title}</h3>
            <p class="text-sm text-slate-500 leading-relaxed mt-0.5">{f.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center mt-12">
      <a href="/features" class="inline-flex items-center gap-2 text-sm font-semibold text-blue-600 hover:text-blue-700">
        See all features in detail
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>
  </div>
</section>
