---
// A reusable "app screenshot" frame: browser chrome + product sidebar.
// Renders a realistic Office Manager UI shell around slotted screen content.
interface Props {
  url?: string;
  active?: string;
  title?: string;
}
const { url = 'app.officemanager.io', active = 'Dashboard', title } = Astro.props;
const nav = [
  { label: 'Dashboard', icon: 'grid' },
  { label: 'Leases', icon: 'doc' },
  { label: 'Tickets', icon: 'wrench' },
  { label: 'Vendors', icon: 'users' },
  { label: 'HVAC', icon: 'gear' },
  { label: 'Waivers', icon: 'pen' },
  { label: 'Reports', icon: 'chart' },
];
const icons: Record<string, string> = {
  grid: '<rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>',
  doc: '<path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/>',
  wrench: '<path d="M14.7 6.3a4 4 0 01-5 5L4 17v3h3l5.7-5.7a4 4 0 015-5l-2.3 2.3-2-2 2.3-2.3z"/>',
  users: '<circle cx="9" cy="7" r="3"/><path d="M3 21v-1a5 5 0 015-5h2a5 5 0 015 5v1"/><path d="M17 7a3 3 0 010 6"/>',
  gear: '<circle cx="12" cy="12" r="3"/><path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"/>',
  pen: '<path d="M4 20h4l10-10a2.8 2.8 0 00-4-4L4 16v4z"/><path d="M13.5 6.5l4 4"/>',
  chart: '<path d="M5 21V10M12 21V4M19 21v-7"/>',
};
---
<div class="bg-white rounded-2xl border border-slate-200 shadow-2xl shadow-slate-900/10 overflow-hidden">
  <!-- Browser chrome -->
  <div class="bg-slate-100 px-4 py-3 flex items-center gap-2 border-b border-slate-200">
    <div class="flex gap-1.5">
      <div class="w-3 h-3 rounded-full bg-red-400"></div>
      <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
      <div class="w-3 h-3 rounded-full bg-green-400"></div>
    </div>
    <div class="flex-1 mx-4 bg-white rounded-md px-3 py-1 text-xs text-slate-400 text-center border border-slate-200 truncate">
      {url}
    </div>
  </div>
  <div class="flex" style="min-height:340px">
    <!-- Sidebar -->
    <div class="hidden sm:flex flex-col w-44 border-r border-slate-100 bg-slate-50 p-3 gap-0.5 flex-shrink-0">
      <div class="text-[10px] font-semibold text-slate-400 uppercase tracking-wide px-2 mb-2">Navigation</div>
      {nav.map(item => (
        <div class={`flex items-center gap-2 rounded-lg px-3 py-2 text-sm ${item.label === active ? 'bg-blue-600 text-white font-medium' : 'text-slate-500'}`}>
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" set:html={icons[item.icon]} />
          {item.label}
        </div>
      ))}
    </div>
    <!-- Main content -->
    <div class="flex-1 p-5 overflow-hidden">
      {title && <div class="text-base font-bold text-slate-900 mb-4">{title}</div>}
      <slot />
    </div>
  </div>
</div>
