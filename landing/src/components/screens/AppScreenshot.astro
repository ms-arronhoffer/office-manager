---
// Renders a real product screenshot inside a browser-window chrome.
// The image is an actual captured screen of the application (see
// /public/screenshots), so the marketing site shows exact app imagery
// rather than a hand-built mockup.
interface Props {
  src: string;
  alt: string;
  url?: string;
}
const { src, alt, url = 'app.portfoliodesk.io' } = Astro.props;
---
<div class="bg-white rounded-2xl border border-slate-200 shadow-2xl shadow-slate-900/10 overflow-hidden">
  <!-- Browser chrome -->
  <div class="bg-slate-100 px-4 py-3 flex items-center gap-2 border-b border-slate-200">
    <div class="flex gap-1.5">
      <div class="w-3 h-3 rounded-full bg-red-400"></div>
      <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
      <div class="w-3 h-3 rounded-full bg-green-400"></div>
    </div>
    <div class="flex-1 mx-4 bg-white rounded-md px-3 py-1 text-xs text-slate-400 text-center border border-slate-200 truncate">
      {url}
    </div>
  </div>
  <!-- Actual application screenshot -->
  <img src={src} alt={alt} width="1440" height="900" loading="lazy" decoding="async" class="block w-full h-auto" />
</div>
