---
import AppShell from './AppShell.astro';
const bars = [42, 55, 48, 61, 58, 72, 69, 80, 76, 88, 84, 96];
const max = 100;
const stats = [
  { label: 'SLA Compliance', val: '98%', sub: '+7 pts QoQ' },
  { label: 'Cost / sq ft', val: '$42.10', sub: '-3.4% YoY' },
  { label: 'Open Backlog', val: '12', sub: '-18 this wk' },
];
---
<AppShell active="Reports" url="app.officemanager.io/reports" title="Portfolio Analytics">
  <div class="grid grid-cols-3 gap-3 mb-4">
    {stats.map(s => (
      <div class="bg-slate-50 rounded-xl p-3 border border-slate-100">
        <div class="text-xs text-slate-500">{s.label}</div>
        <div class="text-xl font-bold text-slate-800 mt-0.5">{s.val}</div>
        <div class="text-[11px] text-green-600 font-medium">{s.sub}</div>
      </div>
    ))}
  </div>
  <div class="rounded-xl border border-slate-200 p-4">
    <div class="flex items-center justify-between mb-3">
      <div class="text-xs font-semibold text-slate-500">SLA compliance trend</div>
      <div class="text-[10px] text-slate-400">Last 12 months</div>
    </div>
    <div class="flex items-end gap-1.5 h-32">
      {bars.map((b, i) => (
        <div class="flex-1 flex flex-col justify-end">
          <div
            class={`rounded-t ${i === bars.length - 1 ? 'bg-blue-600' : 'bg-blue-200'}`}
            style={`height:${(b / max) * 100}%`}
          ></div>
        </div>
      ))}
    </div>
    <div class="mt-3 flex items-center gap-3 text-[11px] text-slate-400">
      <button class="px-2.5 py-1 rounded-md bg-slate-900 text-white font-medium">Export PDF</button>
      <button class="px-2.5 py-1 rounded-md border border-slate-200 text-slate-600 font-medium">Export CSV</button>
    </div>
  </div>
</AppShell>
