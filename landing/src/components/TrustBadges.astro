---
// Credibility badges shown under the hero CTA and near pricing. Each badge maps
// to a real product capability (audit log, RBAC, ESIGN/UETA waivers, Gemini AI,
// encryption) so nothing here overstates certification status.
const badges = [
  {
    label: 'Bank-grade encryption',
    icon: `<rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/>`,
  },
  {
    label: 'Role-based access & full audit log',
    icon: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/>`,
  },
  {
    label: 'ESIGN/UETA e-signatures',
    icon: `<path d="M3 17c3-1 4-4 6-4s3 3 6 2 3-4 6-4"/><path d="M16 3l5 5-9 9-5 1 1-5 8-8z"/>`,
  },
  {
    label: 'AI powered by Google Gemini',
    icon: `<path d="M12 2l2.4 6.6L21 11l-6.6 2.4L12 20l-2.4-6.6L3 11l6.6-2.4L12 2z"/>`,
  },
];
---
<div class="max-w-4xl mx-auto">
  <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-4">
    Built for compliance-minded real estate &amp; facilities teams
  </p>
  <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3">
    {badges.map(b => (
      <div class="inline-flex items-center gap-2 text-sm font-medium text-slate-600">
        <svg class="w-4 h-4 text-blue-600 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" set:html={b.icon} />
        {b.label}
      </div>
    ))}
  </div>
</div>
