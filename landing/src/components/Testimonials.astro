---
const quotes = [
  {
    quote: "We were running a 47-location portfolio out of Excel. After six months on Portfolio Desk, our whole team is self-sufficient and we haven't missed a single deadline.",
    name: "Sarah L.",
    role: "VP Corporate Real Estate, Financial Services",
    initials: "SL",
    metric: "0 missed deadlines in 6 months",
  },
  {
    quote: "The maintenance ticket system alone paid for the subscription in the first month. Our SLA compliance went from 71% to 96% in 90 days.",
    name: "Marcus K.",
    role: "Facilities Director, Technology Company",
    initials: "MK",
    metric: "71% → 96% SLA compliance",
  },
  {
    quote: "Setup took less than two hours. We imported our lease data from CSV and were operational the same afternoon. The alert system is exactly what we needed.",
    name: "Jennifer P.",
    role: "Real Estate Manager, Healthcare Organization",
    initials: "JP",
    metric: "Live the same afternoon",
  },
];
---
<section class="py-24 bg-slate-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="text-sm font-semibold text-blue-600 uppercase tracking-widest mb-3">Customer Stories</p>
      <h2 class="text-4xl lg:text-5xl font-extrabold text-slate-900">What facilities teams are saying</h2>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">
      {quotes.map(q => (
        <div class="bg-white rounded-2xl p-8 border border-slate-200 shadow-sm flex flex-col">
          <div class="text-amber-400 text-xl mb-4">★★★★★</div>
          <div class="inline-flex self-start items-center gap-1.5 rounded-full bg-blue-50 border border-blue-100 text-blue-700 text-xs font-semibold px-3 py-1 mb-4">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            {q.metric}
          </div>
          <blockquote class="text-slate-600 leading-relaxed flex-1">
            "{q.quote}"
          </blockquote>
          <div class="mt-6 flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center text-white text-sm font-bold flex-shrink-0">
              {q.initials}
            </div>
            <div>
              <div class="font-semibold text-slate-900 text-sm">{q.name}</div>
              <div class="text-xs text-slate-400 mt-0.5">{q.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <p class="text-center text-sm text-slate-400 mt-10">
      Names abbreviated at customers' request.
      <a href="/contact" class="font-semibold text-blue-600 hover:text-blue-700">Ask us for references &amp; full case studies →</a>
    </p>
  </div>
</section>
