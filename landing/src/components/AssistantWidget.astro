---
// Self-contained "instant answers" widget. Reduces drop-off from prospects with
// specific objections by answering common questions right on the page. It is
// intentionally NOT connected to any third-party chat service or external API —
// answers are a bundled, keyword-matched knowledge base, so no visitor data ever
// leaves the browser. Anything it can't answer routes to the contact form.
const faqs = [
  {
    q: 'How much does it cost?',
    keys: ['price', 'cost', 'pricing', 'plan', 'how much'],
    a: 'Starter is $99/mo (10 offices, 100 active leases), Pro is $399/mo (50 offices, 500 leases), and Enterprise is custom. Every plan is unlimited users and includes a 14-day free trial, no card required. Switch to annual billing to save ~20%.',
  },
  {
    q: 'Can you migrate my data from Buildium?',
    keys: ['buildium', 'migrate', 'migration', 'import', 'switch', 'move'],
    a: "Yes. Our guided migration assistant moves your leases, tenants, vendors and GL mappings from Buildium in hours, not weeks, and it's free. See the migration section above or contact us to walk through it.",
  },
  {
    q: 'What can the AI do?',
    keys: ['ai', 'gemini', 'abstract', 'extract', 'summary', 'report'],
    a: 'Powered by Google Gemini, the AI reads uploaded leases to extract key terms, drafts lease abstracts, and writes weekly/monthly briefings of upcoming notice periods, expirations and maintenance. Try the live demo above on a sample lease.',
  },
  {
    q: 'Is my data secure?',
    keys: ['secure', 'security', 'gdpr', 'soc', 'audit', 'encryption', 'compliance', 'sso', 'saml'],
    a: 'Data is encrypted, access is role-based, and every action is captured in a full audit log. Enterprise adds SSO/SAML and custom data-retention policies. Digital waivers conform to ESIGN/UETA e-signature standards.',
  },
  {
    q: 'How long does setup take?',
    keys: ['setup', 'implement', 'onboard', 'start', 'how long', 'trial'],
    a: 'Most teams are operational the same day. Import leases from CSV (or migrate from Buildium), set your alert rules, and go, no six-month implementation or consultant required.',
  },
];
---
<div id="assistant" class="fixed bottom-5 right-5 z-40">
  <!-- Launcher -->
  <button id="asst-launch" type="button" aria-expanded="false" aria-controls="asst-panel"
    class="flex items-center gap-2 bg-slate-900 text-white font-semibold pl-4 pr-5 py-3 rounded-full shadow-xl hover:bg-slate-700 transition-colors">
    <svg class="w-5 h-5 text-blue-400" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12a9 9 0 01-9 9 9 9 0 01-4-.94L3 21l1.06-4A9 9 0 1121 12z"/></svg>
    Ask about Portfolio Desk
  </button>

  <!-- Panel -->
  <div id="asst-panel" class="hidden absolute bottom-16 right-0 w-[22rem] max-w-[calc(100vw-2.5rem)] rounded-2xl bg-white border border-slate-200 shadow-2xl overflow-hidden">
    <div class="bg-slate-900 px-4 py-3 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <span class="w-2 h-2 rounded-full bg-green-400"></span>
        <span class="text-sm font-semibold text-white">Instant answers</span>
      </div>
      <button id="asst-close" type="button" aria-label="Close" class="text-slate-400 hover:text-white">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>

    <div id="asst-log" class="px-4 py-4 space-y-3 max-h-80 overflow-y-auto text-sm">
      <div class="flex gap-2">
        <div class="flex-1 rounded-xl rounded-tl-none bg-slate-100 px-3 py-2 text-slate-700">
          Hi! Ask me anything, or tap a question below.
        </div>
      </div>
      <div id="asst-suggestions" class="flex flex-wrap gap-2">
        {faqs.map((f, i) => (
          <button type="button" class="asst-suggest text-left text-xs font-medium text-blue-700 bg-blue-50 border border-blue-100 rounded-full px-3 py-1.5 hover:bg-blue-100 transition-colors" data-idx={i}>
            {f.q}
          </button>
        ))}
      </div>
    </div>

    <form id="asst-form" class="border-t border-slate-200 p-3 flex items-center gap-2">
      <input id="asst-input" type="text" autocomplete="off" placeholder="Type your question…"
        class="flex-1 rounded-lg border border-slate-300 px-3 py-2 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100 transition" />
      <button type="submit" aria-label="Send" class="bg-slate-900 text-white p-2 rounded-lg hover:bg-slate-700 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6"/></svg>
      </button>
    </form>
  </div>
</div>

<script is:inline define:vars={{ faqs }}>
  (function () {
    var launch = document.getElementById('asst-launch');
    if (!launch) return;
    var panel = document.getElementById('asst-panel');
    var close = document.getElementById('asst-close');
    var log = document.getElementById('asst-log');
    var form = document.getElementById('asst-form');
    var input = document.getElementById('asst-input');

    function toggle(openIt) {
      var isOpen = openIt !== undefined ? openIt : panel.classList.contains('hidden');
      panel.classList.toggle('hidden', !isOpen);
      launch.setAttribute('aria-expanded', String(isOpen));
      if (isOpen) input.focus();
    }
    launch.addEventListener('click', function () { toggle(); });
    close.addEventListener('click', function () { toggle(false); });

    function bubble(text, who) {
      var wrap = document.createElement('div');
      wrap.className = 'flex gap-2' + (who === 'user' ? ' justify-end' : '');
      var b = document.createElement('div');
      if (who === 'user') {
        b.className = 'max-w-[85%] rounded-xl rounded-tr-none bg-slate-900 text-white px-3 py-2';
      } else {
        b.className = 'max-w-[85%] rounded-xl rounded-tl-none bg-slate-100 text-slate-700 px-3 py-2';
      }
      b.textContent = text;
      wrap.appendChild(b);
      log.appendChild(wrap);
      log.scrollTop = log.scrollHeight;
      return b;
    }

    function answerFor(text) {
      var t = (text || '').toLowerCase();
      var best = null, bestScore = 0;
      faqs.forEach(function (f) {
        var score = 0;
        f.keys.forEach(function (k) { if (t.indexOf(k) !== -1) score += 1; });
        if (score > bestScore) { bestScore = score; best = f; }
      });
      if (best && bestScore > 0) return best.a;
      return null;
    }

    function respond(text) {
      var ans = answerFor(text);
      setTimeout(function () {
        if (ans) {
          bubble(ans, 'bot');
        } else {
          var b = bubble("Great question — I'll connect you with the team for that. ", 'bot');
          var a = document.createElement('a');
          a.href = '/contact';
          a.textContent = 'Contact us →';
          a.className = 'font-semibold text-blue-600 hover:text-blue-700';
          b.appendChild(a);
        }
      }, 350);
    }

    Array.prototype.forEach.call(document.querySelectorAll('.asst-suggest'), function (btn) {
      btn.addEventListener('click', function () {
        var f = faqs[Number(btn.getAttribute('data-idx'))];
        bubble(f.q, 'user');
        respond(f.q);
      });
    });

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var v = input.value.trim();
      if (!v) return;
      bubble(v, 'user');
      input.value = '';
      respond(v);
    });
  })();
</script>
