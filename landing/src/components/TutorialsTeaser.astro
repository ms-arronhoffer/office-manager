---
import { tutorials } from '../config/site';
const featured = tutorials.slice(0, 3);
---
<section class="py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-12">
      <div>
        <p class="text-sm font-semibold text-blue-600 uppercase tracking-widest mb-3">Tutorials</p>
        <h2 class="text-4xl lg:text-5xl font-extrabold text-slate-900">Learn it in minutes</h2>
        <p class="mt-4 text-lg text-slate-500 max-w-xl">Short, practical guides that take you from first login to board-ready reporting.</p>
      </div>
      <a href="/tutorials" class="inline-flex items-center gap-2 text-sm font-semibold text-blue-600 hover:text-blue-700 flex-shrink-0">
        Browse all guides
        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {featured.map(t => (
        <a href={`/tutorials/${t.slug}`} class="group flex flex-col p-6 rounded-2xl border border-slate-200 bg-white hover:border-blue-200 hover:shadow-lg hover:shadow-blue-50 transition-all duration-200">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-xs font-semibold px-2.5 py-0.5 rounded-full bg-blue-100 text-blue-700">{t.level}</span>
            <span class="text-xs text-slate-400">{t.minutes} min read</span>
          </div>
          <h3 class="font-bold text-slate-900 text-lg leading-snug group-hover:text-blue-700 transition-colors">{t.title}</h3>
          <p class="mt-2 text-sm text-slate-500 leading-relaxed flex-1">{t.summary}</p>
          <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-blue-600">
            Read guide
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
