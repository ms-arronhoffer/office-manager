---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Portfolio Desk: Every Office. Every Lease. Every Deadline.",
  description = "The all-in-one platform for corporate real estate and facilities teams. Manage leases, maintenance, vendors, and compliance in one place.",
} = Astro.props;
const canonical = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons/favicon-32.png" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    <meta name="theme-color" content="#0E213D" />

    <!-- Open Graph / social preview -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400..900;1,14..32,400..900&display=swap" rel="stylesheet" />
    <script is:inline src="/config.js"></script>
  </head>
  <body class="font-sans">
    <slot />

    <!-- Wire all [data-href] CTAs from SITE_CONFIG at runtime, and brand name. -->
    <!-- Note: contact is handled by the on-site /contact form, so no email
         address is ever placed in the HTML for spam harvesters to scrape. -->
    <script is:inline>
      (function () {
        var cfg = window.SITE_CONFIG || {};
        document.querySelectorAll('[data-href]').forEach(function (el) {
          var url = cfg[el.getAttribute('data-href')];
          if (!url) return;
          if (el.tagName === 'A') {
            el.href = url;
          } else {
            el.addEventListener('click', function () { window.location.href = url; });
            el.style.cursor = 'pointer';
          }
        });
        document.querySelectorAll('[data-company]').forEach(function (el) {
          el.textContent = cfg.COMPANY_NAME || 'Portfolio Desk';
        });
      })();
    </script>
  </body>
</html>
