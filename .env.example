# Database
POSTGRES_DB=office_manager
POSTGRES_USER=office_admin
POSTGRES_PASSWORD=change_this_password

# JWT
JWT_SECRET=change_this_to_a_random_secret_key

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@officemanager.local
# Address that receives in-app support requests (Administration > Support
# Requests). Leave blank to disable email forwarding; requests are still
# stored and visible to admins in-app.
SUPPORT_EMAIL=

# AI assist — Google Gemini (optional; enables AI lease ingestion, abstract
# suggestions and summary reports). Leave GEMINI_API_KEY blank to disable.
# Model name, API key and endpoint are all configurable here.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_SECONDS=60

# Symmetric encryption key used to store third-party secrets we must send
# back out verbatim (e.g. the Buildium migration connector's API client
# secret) — see app.utils.crypto. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required in production; without it, secrets are stored unencrypted (dev only).
ENCRYPTION_KEY=

# Buildium migration connector (Administration > System & Data). Credentials
# are entered per-organization in the admin UI, not here; these just tune the
# HTTP client's defaults.
BUILDIUM_API_BASE_URL=https://api.buildium.com/v1
BUILDIUM_TIMEOUT_SECONDS=60

# Frontend
FRONTEND_URL=http://localhost:3000
APP_PORT=3000
ADMIN_FRONTEND_URL=http://localhost:4001
ADMIN_PORT=4001
LANDING_PORT=4002

# Default Admin — set a strong password; this account is created on first startup
DEFAULT_ADMIN_EMAIL=admin@officemanager.local
DEFAULT_ADMIN_PASSWORD=change_this_password
# Optional: comma-separated emails promoted to super-admin on every startup
SUPER_ADMIN_EMAILS=

# ── Observability (optional) ─────────────────────────────────────────
# Deployment environment label used to tag logs and Sentry events.
APP_ENV=development
# Root log level: DEBUG / INFO / WARNING / ERROR.
LOG_LEVEL=INFO
# Log output: "plain" (human-readable) or "json" (structured, for aggregation).
LOG_FORMAT=plain
# Error tracking via Sentry. Leave SENTRY_DSN blank to disable.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
