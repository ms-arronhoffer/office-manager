# Database
POSTGRES_DB=office_manager
POSTGRES_USER=office_admin
POSTGRES_PASSWORD=change_this_password

# JWT
JWT_SECRET=change_this_to_a_random_secret_key

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@officemanager.local
# Address that receives in-app support requests (Administration > Support
# Requests). Leave blank to disable email forwarding; requests are still
# stored and visible to admins in-app.
SUPPORT_EMAIL=

# AI assist — Google Gemini (optional; enables AI lease ingestion, abstract
# suggestions and summary reports). Leave GEMINI_API_KEY blank to disable.
# Model name, API key and endpoint are all configurable here.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_SECONDS=60

# Symmetric encryption key used to store third-party secrets we must send
# back out verbatim (e.g. the Buildium migration connector's API client
# secret) — see app.utils.crypto. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Required in production; without it, secrets are stored unencrypted (dev only).
ENCRYPTION_KEY=

# Buildium migration connector (Administration > System & Data). Credentials
# are entered per-organization in the admin UI, not here; these just tune the
# HTTP client's defaults.
BUILDIUM_API_BASE_URL=https://api.buildium.com/v1
BUILDIUM_TIMEOUT_SECONDS=60

# Frontend
# Host ports below must match the docker-compose.prod.yml defaults and each
# other; they are bound on 127.0.0.1 for a reverse proxy (Nginx Proxy Manager)
# to reach. Keep all four distinct — reusing a port makes a second container
# fail to bind. Running prod: frontend=4001, backend=4002, landing=4003,
# admin=4004.
FRONTEND_URL=http://localhost:4001
APP_PORT=4001
ADMIN_FRONTEND_URL=http://localhost:4004
ADMIN_PORT=4004
LANDING_PORT=4003
# Host port the backend API is mapped to (used by docker-compose.prod.yml so a
# reverse proxy such as Nginx Proxy Manager can reach the API directly).
BACKEND_PORT=4002

# ── Nginx Proxy Manager (prod ingress) ───────────────────────────────
# docker-compose.prod.yml runs Nginx Proxy Manager as the single public
# ingress (ports 80/443, plus the admin UI on 81). These variables drive the
# idempotent route/SSL provisioner infra/nginx-proxy-manager/bootstrap.py.
# Pin the image; leave blank to use the compose default.
NPM_IMAGE_TAG=2.15.1
# NPM admin API + credentials (defaults match a fresh NPM install; rotate the
# admin account after first boot and update these).
NPM_BASE_URL=http://localhost:81
NPM_ADMIN_EMAIL=admin@example.com
NPM_ADMIN_PASSWORD=changeme
# Email used when requesting Let's Encrypt certificates. Leave blank to skip SSL
# (routes are served over HTTP only until this is set and the script re-run).
NPM_LETSENCRYPT_EMAIL=
# Public domains to expose. Only the ones you set are provisioned; each maps to
# the matching container over the shared `edge` network. NPM_API_DOMAIN is
# optional (the SPA usually calls the API under the same domain via /api).
NPM_FRONTEND_DOMAIN=
NPM_ADMIN_DOMAIN=
NPM_LANDING_DOMAIN=
NPM_API_DOMAIN=

# File storage backend for uploaded attachments: "local" (default; files under
# UPLOAD_DIR) or "s3" (required in the AWS deployment — see
# docs/aws-deployment.md — so uploads survive a container being replaced or
# more than one backend instance running). S3_UPLOAD_BUCKET is required when
# STORAGE_BACKEND=s3; the app authenticates to AWS via the default boto3
# credential chain (e.g. the EC2 instance role), not env-var keys.
STORAGE_BACKEND=local
S3_UPLOAD_BUCKET=
S3_UPLOAD_PREFIX=uploads
AWS_REGION=us-east-2

# Default Admin — set a strong password; this account is created on first startup
DEFAULT_ADMIN_EMAIL=admin@officemanager.local
DEFAULT_ADMIN_PASSWORD=change_this_password
# Optional: comma-separated emails promoted to super-admin on every startup
SUPER_ADMIN_EMAILS=

# ── Observability (optional) ─────────────────────────────────────────
# Deployment environment label used to tag logs and Sentry events.
APP_ENV=development
# Root log level: DEBUG / INFO / WARNING / ERROR.
LOG_LEVEL=INFO
# Log output: "plain" (human-readable) or "json" (structured, for aggregation).
LOG_FORMAT=plain
# Error tracking via Sentry. Leave SENTRY_DSN blank to disable.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
